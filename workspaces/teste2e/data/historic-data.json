    {
      "id": "TP-SARAJEVO-1914",
      "title": "Sarajevo Assassination & WWI Outbreak",
      "title_zh": "萨拉热窝事件与第一次世界大战爆发",
      "era": "近现代",
      "year": "1914",
      "summary": "奥匈帝国皇储斐迪南大公遇刺触发同盟体系连锁反应，欧洲列强在一个月内全面卷入战争，终结百年欧洲协调体系，重塑全球地缘格局。",
      "before_summary": "欧洲维持'大国协调'均势体系，英德海军竞赛加剧但尚未破裂，巴尔干为'欧洲火药桶'。",
      "after_summary": "四大帝国崩溃（奥匈、奥斯曼、沙俄、德意志），凡尔赛体系建立，美国登上世界舞台，苏联诞生。",
      "related_countries": [
        "HRE",
        "GBR",
        "FRA",
        "RUS",
        "AUT",
        "OTM",
        "ITA",
        "BEL"
